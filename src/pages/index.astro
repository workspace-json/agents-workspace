---
// Homepage — custom Astro page using StarlightPage for nav/footer wrapper
// Per spec §3.1 and R27.7: hero with wordmark + 2 outlined buttons + 3 prose sections
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
---

<StarlightPage
	frontmatter={{
		title: 'workspace.json',
		description: 'Structured codebase intelligence that AI coding agents can rely on.',
	}}
	hasSidebar={false}
>
	<div class="wj-hero">
		<h1 class="wj-hero__title">workspace.json</h1>
		<p class="wj-hero__tagline">Structured codebase intelligence that AI coding agents can rely on.</p>
		<div class="wj-hero__actions">
			<a href="/spec/" class="wj-btn wj-btn--outline">Read the spec</a>
			<a href="/audit/" class="wj-btn wj-btn--outline">Try the audit tool</a>
		</div>
	</div>

	<div class="wj-prose">
		<section>
			<h2>What it is</h2>
			<p>
				workspace.json is a JSON file that describes a codebase to AI agents.
				It captures file structure, conventions, framework versions, and
				fragility signals derived from observing how the codebase is actually
				used. Tools generate it, agents read it, and developers commit it
				to git so the entire team's tooling shares the same view of reality.
			</p>
			<p>
				It's an open spec, Apache 2.0 licensed, and proposed as a complement
				to AGENTS.md.
			</p>
		</section>

		<section>
			<h2>Why it exists</h2>
			<p>
				AGENTS.md gave AI coding tools a place to read instructions. But
				instructions are prose, written by humans, and they go stale fast.
				A codebase changes; the file describing it doesn't.
			</p>
			<p>
				workspace.json is for the descriptive layer — what's true about
				the code right now. It's regenerated by tools that observe the
				codebase, so it stays current. AI agents read both AGENTS.md and
				workspace.json: prescriptive context plus descriptive context.
			</p>
		</section>

		<section>
			<h2>How it relates to AGENTS.md</h2>
			<p>The two files are designed to compose:</p>
			<ul>
				<li><strong>AGENTS.md:</strong> what agents should do (prescriptive, prose, human-authored)</li>
				<li><strong>workspace.json:</strong> what's true about the codebase (descriptive, structured, tool-generated)</li>
			</ul>
			<p>
				A repo can have both, neither, or either. Tools that consume
				AGENTS.md continue to work unchanged. Tools that also consume
				workspace.json get richer context.
			</p>
		</section>

		<nav class="wj-pointers" aria-label="Key links">
			<a href="/spec/">Read the v0.1 spec &rarr;</a>
			<a href="/audit/">Try agents-audit, the reference CLI &rarr;</a>
			<a href="/examples/">See examples from real repos &rarr;</a>
		</nav>
	</div>
</StarlightPage>

<style>
	.wj-hero {
		text-align: center;
		padding: 4rem 0 3rem;
	}

	.wj-hero__title {
		font-size: 2.5rem;
		font-weight: 700;
		letter-spacing: -0.025em;
		margin: 0 0 1rem;
	}

	.wj-hero__tagline {
		font-size: 1.125rem;
		color: var(--sl-color-gray-5);
		max-width: 36rem;
		margin: 0 auto 2rem;
		line-height: 1.6;
	}

	.wj-hero__actions {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.wj-btn {
		display: inline-block;
		padding: 0.625rem 1.25rem;
		border-radius: 6px;
		font-size: 0.9375rem;
		font-weight: 500;
		text-decoration: none;
		min-height: 44px;
		line-height: 1.75;
	}

	.wj-btn--outline {
		border: 1.5px solid var(--sl-color-accent);
		color: var(--sl-color-accent);
		background: transparent;
	}

	.wj-btn--outline:hover {
		background: var(--sl-color-accent-low);
	}

	.wj-prose {
		max-width: 45rem;
		margin: 0 auto;
		padding: 0 1rem;
	}

	.wj-prose section {
		margin-bottom: 2.5rem;
	}

	.wj-prose h2 {
		font-size: 1.25rem;
		font-weight: 600;
		margin: 0 0 0.75rem;
	}

	.wj-prose p {
		line-height: 1.65;
		color: var(--sl-color-text);
		margin: 0 0 1rem;
	}

	.wj-prose ul {
		margin: 0.5rem 0 1rem 1.25rem;
		line-height: 1.65;
	}

	.wj-pointers {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding: 2rem 0 3rem;
	}

	.wj-pointers a {
		color: var(--sl-color-text-accent);
		text-decoration: none;
		font-size: 0.9375rem;
	}

	.wj-pointers a:hover {
		text-decoration: underline;
	}
</style>
